<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.github.damirm.clipwipe</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/clipwipe</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/tmp/clipwipe.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/clipwipe.err</string>
</dict>
</plist>
